# Build artifacts
/dist/
/bin/
# Anchored to the repo root so this only ignores a stray binary built here — without
# it, the pattern also matches the cmd/docs-sign/ source directory and hides it from git.
/docs-sign
*.exe

# Embedded frontend build output (generated by `npm run build`).
# Keep the directory (and its placeholder) so the Go embed always compiles,
# but ignore the actual built artifacts.
/internal/web/dist/*
!/internal/web/dist/placeholder.html

# Runtime data (encrypted blobs + sqlite db) — never commit
/data/
*.db
*.db-wal
*.db-shm
*.enc

# Node
web/node_modules/
web/dist/
npm-debug.log*

# Go
*.test
*.out
/coverage.out

# Editor/OS
.DS_Store
.idea/
.vscode/
*.swp
